# Powers trend triage, visual scout context, copy variants, dashboard AI rewrites,
# safety review, source-finding hints, and schedule suggestions.
ANTHROPIC_API_KEY=

# Optional discovery credentials.
# Reddit RSS works without credentials; API credentials improve reliability and richer metrics.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=content-clipping-trend-scout/0.1

# X/Twitter discovery requires paid/approved API access for automated search.
X_BEARER_TOKEN=

YT_CLIENT_SECRETS_FILE=secrets/yt_client_secret.json
YT_TOKEN_FILE=secrets/yt_token.json

IG_USER_ID=
IG_ACCESS_TOKEN=
IG_PUBLIC_CLIP_BASE=

TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional external AI/video editing and automation integrations.
# Enable the matching provider in config.yaml before using these.
PALMIER_MCP_URL=http://127.0.0.1:19789/mcp
PALMIER_APP_PATH=

DESCRIPT_API_TOKEN=
DESCRIPT_MCP_CONNECTED=

SHOTSTACK_API_KEY=
CREATOMATE_API_KEY=
JSON2VIDEO_API_KEY=
RUNWAY_API_KEY=
AYRSHARE_API_KEY=
