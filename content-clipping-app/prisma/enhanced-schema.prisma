// Enhanced Prisma schema with performance optimizations and production indexes

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User and authentication models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId], name: "account_user_id_idx")
  @@index([provider], name: "account_provider_idx")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "session_user_id_idx")
  @@index([expires], name: "session_expires_idx")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // User preferences and settings
  preferences   Json      @default("{}")
  tier          UserTier  @default(FREE)
  
  // Usage tracking
  storageUsed   BigInt    @default(0)
  monthlyUploads Int      @default(0)
  lastResetDate DateTime  @default(now())

  accounts Account[]
  sessions Session[]
  videos   Video[]
  chatConversations ChatConversation[]
  platformAccounts PlatformAccount[]
  publishingCampaigns PublishingCampaign[]
  publishingHistory PublishingHistory[]
  subscriptions UserSubscription[]

  @@index([email], name: "user_email_idx")
  @@index([tier], name: "user_tier_idx")
  @@index([createdAt], name: "user_created_at_idx")
  @@index([storageUsed], name: "user_storage_idx")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires], name: "verification_token_expires_idx")
}

// Enhanced Video model with performance optimizations
model Video {
  id              String         @id @default(cuid())
  title           String
  description     String?        @db.Text
  url             String
  thumbnail       String?
  duration        Int            // in seconds
  fileSize        BigInt         // in bytes
  uploadedAt      DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  status          VideoStatus    @default(UPLOADING)
  processingStage ProcessingStage @default(UPLOADED)
  processingProgress Int         @default(0) // 0-100
  errorMessage    String?        @db.Text
  retryCount      Int            @default(0)
  
  // Video metadata
  metadataExtracted Boolean      @default(false)
  thumbnailGenerated Boolean     @default(false)
  audioExtracted  Boolean        @default(false)
  transcriptionCompleted Boolean @default(false)
  clipsGenerated  Boolean        @default(false)
  width           Int?
  height          Int?
  fps             Float?
  bitrate         Int?
  codec           String?
  
  // Performance tracking
  processingStartedAt DateTime?
  processingCompletedAt DateTime?
  totalProcessingTime Int?       // in milliseconds
  
  // Content hash for deduplication
  contentHash     String?
  
  userId          String

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  clips         Clip[]
  transcription Transcription?
  chatConversations ChatConversation[]
  publishingCampaigns PublishingCampaign[]

  // Performance indexes
  @@index([userId, status], name: "video_user_status_idx")
  @@index([status, processingStage], name: "video_status_stage_idx")
  @@index([uploadedAt], name: "video_uploaded_at_idx")
  @@index([processingStage, processingProgress], name: "video_processing_idx")
  @@index([contentHash], name: "video_content_hash_idx")
  @@index([userId, uploadedAt], name: "video_user_uploaded_idx")
  @@index([fileSize], name: "video_file_size_idx")
  @@index([duration], name: "video_duration_idx")
}

// Enhanced Clip model with revenue tracking
model Clip {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  startTime   Int      // in seconds
  endTime     Int      // in seconds
  duration    Int      @default(0) // Computed duration
  tags        String[] @default([])
  exported    Boolean  @default(false)
  exportUrl   String?
  
  // AI scoring
  score       Float?   // engagement score 0-1
  confidence  Float?   // confidence in clip quality 0-1
  reason      String?  @db.Text // why this clip was suggested
  
  // User interaction
  approved    Boolean  @default(false)
  rejected    Boolean  @default(false)
  viewCount   Int      @default(0)
  
  // Revenue tracking
  estimatedRevenue Float @default(0.0)
  actualRevenue   Float  @default(0.0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  videoId     String

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  publishingCampaigns PublishingCampaign[]
  clipAnalytics ClipAnalytics[]

  @@index([videoId], name: "clip_video_id_idx")
  @@index([exported], name: "clip_exported_idx")
  @@index([approved], name: "clip_approved_idx")
  @@index([score], name: "clip_score_idx")
  @@index([videoId, score], name: "clip_video_score_idx")
  @@index([createdAt], name: "clip_created_at_idx")
  @@index([estimatedRevenue], name: "clip_revenue_idx")
  @@index([duration], name: "clip_duration_idx")
}

// Enhanced Transcription model
model Transcription {
  id        String                @id @default(cuid())
  text      String                @db.Text
  language  String?
  confidence Float?               // Overall transcription confidence
  wordCount Int                   @default(0)
  segments  TranscriptionSegment[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  videoId   String                @unique

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId], name: "transcription_video_id_idx")
  @@index([language], name: "transcription_language_idx")
  @@index([confidence], name: "transcription_confidence_idx")
}

model TranscriptionSegment {
  id              String        @id @default(cuid())
  text            String        @db.Text
  startTime       Float         // in seconds with decimal precision
  endTime         Float         // in seconds with decimal precision
  duration        Float         @default(0.0) // Computed duration
  confidence      Float?        // confidence score 0-1
  speakerLabel    String?       // speaker identification if available
  wordCount       Int           @default(0)
  transcriptionId String

  transcription Transcription @relation(fields: [transcriptionId], references: [id], onDelete: Cascade)

  @@index([transcriptionId], name: "segment_transcription_id_idx")
  @@index([startTime], name: "segment_start_time_idx")
  @@index([confidence], name: "segment_confidence_idx")
  @@index([speakerLabel], name: "segment_speaker_idx")
  @@index([transcriptionId, startTime], name: "segment_transcription_time_idx")
}

// Enhanced social media models with revenue tracking
model SocialPlatform {
  id              String            @id @default(cuid())
  name            String            // 'youtube', 'tiktok', 'instagram', 'twitter'
  displayName     String
  isActive        Boolean           @default(true)
  apiVersion      String?
  rateLimit       Json?             // Rate limiting configuration
  revenueRate     Float             @default(0.0) // Average revenue per 1000 views
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  platformAccounts PlatformAccount[]
  publishingCampaigns PublishingCampaign[]

  @@unique([name])
  @@index([name], name: "platform_name_idx")
  @@index([isActive], name: "platform_active_idx")
}

model PlatformAccount {
  id              String            @id @default(cuid())
  userId          String
  platformId      String
  accountId       String            // Platform-specific account ID
  username        String?
  displayName     String?
  profilePicture  String?
  accessToken     String?           @db.Text
  refreshToken    String?           @db.Text
  tokenExpiresAt  DateTime?
  scopes          String[]          @default([])
  isActive        Boolean           @default(true)
  lastSyncAt      DateTime?
  settings        Json              @default("{}")
  
  // Revenue tracking
  totalRevenue    Float             @default(0.0)
  monthlyRevenue  Float             @default(0.0)
  lastRevenueUpdate DateTime?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform          SocialPlatform   @relation(fields: [platformId], references: [id], onDelete: Cascade)
  publishingCampaigns PublishingCampaign[]
  publishedContent  PublishedContent[]
  analytics         PlatformAnalytics[]
  scheduledPosts    ScheduledPost[]
  publishingHistory PublishingHistory[]
  optimalPostingTimes OptimalPostingTime[]
  revenueAnalytics  RevenueAnalytics[]

  @@unique([userId, platformId, accountId])
  @@index([userId], name: "platform_account_user_id_idx")
  @@index([platformId], name: "platform_account_platform_id_idx")
  @@index([isActive], name: "platform_account_active_idx")
  @@index([lastSyncAt], name: "platform_account_sync_idx")
  @@index([totalRevenue], name: "platform_account_revenue_idx")
  @@index([userId, platformId], name: "platform_account_user_platform_idx")
}

// Enhanced Publishing Campaign with better tracking
model PublishingCampaign {
  id              String               @id @default(cuid())
  title           String
  description     String?              @db.Text
  userId          String
  clipId          String?
  videoId         String?
  platformId      String
  accountId       String
  status          PublishingStatus     @default(DRAFT)
  scheduledAt     DateTime?
  publishedAt     DateTime?
  autoOptimize    Boolean              @default(true)
  approvalRequired Boolean             @default(false)
  isApproved      Boolean              @default(false)
  approvedAt      DateTime?
  approvedBy      String?
  errorMessage    String?              @db.Text
  retryCount      Int                  @default(0)
  maxRetries      Int                  @default(3)
  metadata        Json                 @default("{}")
  
  // Performance tracking
  processingStartedAt DateTime?
  processingCompletedAt DateTime?
  totalProcessingTime Int?             // in milliseconds
  
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  clip            Clip?                @relation(fields: [clipId], references: [id], onDelete: SetNull)
  video           Video?               @relation(fields: [videoId], references: [id], onDelete: SetNull)
  platform        SocialPlatform       @relation(fields: [platformId], references: [id], onDelete: Cascade)
  account         PlatformAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contentVariations ContentVariation[]
  publishedContent PublishedContent[]
  scheduledPosts  ScheduledPost[]
  contentOptimizations ContentOptimization[]
  publishingHistory PublishingHistory[]

  @@index([userId], name: "campaign_user_id_idx")
  @@index([clipId], name: "campaign_clip_id_idx")
  @@index([videoId], name: "campaign_video_id_idx")
  @@index([platformId], name: "campaign_platform_id_idx")
  @@index([accountId], name: "campaign_account_id_idx")
  @@index([status], name: "campaign_status_idx")
  @@index([scheduledAt], name: "campaign_scheduled_at_idx")
  @@index([publishedAt], name: "campaign_published_at_idx")
  @@index([createdAt], name: "campaign_created_at_idx")
  @@index([userId, status], name: "campaign_user_status_idx")
  @@index([accountId, status], name: "campaign_account_status_idx")
}

// Enhanced Content Variation with optimization tracking
model ContentVariation {
  id              String            @id @default(cuid())
  campaignId      String
  platformName    String            // 'youtube', 'tiktok', 'instagram', 'twitter'
  title           String?
  description     String?           @db.Text
  hashtags        String[]          @default([])
  mentions        String[]          @default([])
  captions        String?           @db.Text
  videoUrl        String?           // Optimized video file path
  thumbnailUrl    String?           // Platform-specific thumbnail
  aspectRatio     String?           // '9:16', '16:9', '1:1'
  duration        Int?              // in seconds
  fileSize        BigInt?           // in bytes
  quality         String?           // 'low', 'medium', 'high', 'original'
  settings        Json              @default("{}")    // Platform-specific settings
  isOptimized     Boolean           @default(false)
  optimizedAt     DateTime?
  
  // Performance metrics
  optimizationScore Float?          // 0-1 score of optimization quality
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  campaign        PublishingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId], name: "variation_campaign_id_idx")
  @@index([platformName], name: "variation_platform_idx")
  @@index([isOptimized], name: "variation_optimized_idx")
  @@index([createdAt], name: "variation_created_at_idx")
  @@index([optimizationScore], name: "variation_score_idx")
}

// Enhanced Published Content with revenue tracking
model PublishedContent {
  id              String            @id @default(cuid())
  campaignId      String
  accountId       String
  platformPostId  String?           // Platform's post ID
  title           String?
  description     String?           @db.Text
  url             String?           // Platform-specific content URL
  thumbnailUrl    String?
  videoUrl        String?
  hashtags        String[]          @default([])
  mentions        String[]          @default([])
  visibility      String?           // 'public', 'private', 'unlisted'
  status          ContentStatus     @default(PUBLISHED)
  publishedAt     DateTime          @default(now())
  lastSyncAt      DateTime?
  metadata        Json              @default("{}")
  
  // Revenue and performance
  currentRevenue  Float             @default(0.0)
  estimatedRevenue Float            @default(0.0)
  lastRevenueUpdate DateTime?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  campaign        PublishingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  account         PlatformAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  analytics       ContentAnalytics[]

  @@unique([accountId, platformPostId])
  @@index([campaignId], name: "content_campaign_id_idx")
  @@index([accountId], name: "content_account_id_idx")
  @@index([status], name: "content_status_idx")
  @@index([publishedAt], name: "content_published_at_idx")
  @@index([lastSyncAt], name: "content_sync_idx")
  @@index([currentRevenue], name: "content_revenue_idx")
  @@index([accountId, publishedAt], name: "content_account_published_idx")
}

// Enhanced Analytics models with revenue focus
model ContentAnalytics {
  id              String            @id @default(cuid())
  contentId       String
  views           BigInt            @default(0)
  likes           BigInt            @default(0)
  comments        BigInt            @default(0)
  shares          BigInt            @default(0)
  saves           BigInt            @default(0)
  impressions     BigInt            @default(0)
  reach           BigInt            @default(0)
  engagementRate  Float             @default(0.0)
  ctr             Float             @default(0.0)    // Click-through rate
  watchTime       BigInt            @default(0)      // in seconds
  completionRate  Float             @default(0.0)
  
  // Revenue calculations
  estimatedRevenue Float            @default(0.0)
  revenuePerView  Float             @default(0.0)
  
  recordedAt      DateTime          @default(now())
  createdAt       DateTime          @default(now())

  content         PublishedContent  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId], name: "analytics_content_id_idx")
  @@index([recordedAt], name: "analytics_recorded_at_idx")
  @@index([views], name: "analytics_views_idx")
  @@index([engagementRate], name: "analytics_engagement_idx")
  @@index([estimatedRevenue], name: "analytics_revenue_idx")
  @@index([contentId, recordedAt], name: "analytics_content_time_idx")
}

// New Revenue Analytics model
model RevenueAnalytics {
  id              String            @id @default(cuid())
  accountId       String
  period          RevenuePeriod
  startDate       DateTime
  endDate         DateTime
  
  // Revenue metrics
  totalRevenue    Float             @default(0.0)
  projectedRevenue Float            @default(0.0)
  averageRPM      Float             @default(0.0) // Revenue per mille
  
  // Performance metrics
  totalViews      BigInt            @default(0)
  totalEngagement BigInt            @default(0)
  contentCount    Int               @default(0)
  
  // Growth metrics
  revenueGrowth   Float             @default(0.0) // vs previous period
  viewsGrowth     Float             @default(0.0)
  
  calculatedAt    DateTime          @default(now())
  createdAt       DateTime          @default(now())

  account         PlatformAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, period, startDate, endDate])
  @@index([accountId], name: "revenue_account_id_idx")
  @@index([period], name: "revenue_period_idx")
  @@index([startDate], name: "revenue_start_date_idx")
  @@index([totalRevenue], name: "revenue_total_idx")
  @@index([calculatedAt], name: "revenue_calculated_at_idx")
}

// New Clip Analytics model
model ClipAnalytics {
  id              String            @id @default(cuid())
  clipId          String
  
  // Performance metrics across all platforms
  totalViews      BigInt            @default(0)
  totalRevenue    Float             @default(0.0)
  avgEngagementRate Float           @default(0.0)
  
  // Platform breakdown
  platformBreakdown Json            @default("{}")
  
  // Predictions
  projectedViews  BigInt            @default(0)
  projectedRevenue Float            @default(0.0)
  
  lastUpdated     DateTime          @default(now())
  createdAt       DateTime          @default(now())

  clip            Clip              @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@unique([clipId])
  @@index([totalRevenue], name: "clip_analytics_revenue_idx")
  @@index([totalViews], name: "clip_analytics_views_idx")
  @@index([lastUpdated], name: "clip_analytics_updated_idx")
}

// Enhanced Platform Analytics
model PlatformAnalytics {
  id              String            @id @default(cuid())
  accountId       String
  period          String            // 'daily', 'weekly', 'monthly'
  startDate       DateTime
  endDate         DateTime
  totalPosts      Int               @default(0)
  totalViews      BigInt            @default(0)
  totalLikes      BigInt            @default(0)
  totalComments   BigInt            @default(0)
  totalShares     BigInt            @default(0)
  avgEngagement   Float             @default(0.0)
  followers       BigInt            @default(0)
  following       BigInt            @default(0)
  profileViews    BigInt            @default(0)
  
  // Revenue metrics
  totalRevenue    Float             @default(0.0)
  averageRPM      Float             @default(0.0)
  
  data            Json              @default("{}")   // Additional platform-specific metrics
  recordedAt      DateTime          @default(now())
  createdAt       DateTime          @default(now())

  account         PlatformAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, period, startDate, endDate])
  @@index([accountId], name: "platform_analytics_account_idx")
  @@index([period], name: "platform_analytics_period_idx")
  @@index([startDate], name: "platform_analytics_start_idx")
  @@index([endDate], name: "platform_analytics_end_idx")
  @@index([recordedAt], name: "platform_analytics_recorded_idx")
  @@index([totalRevenue], name: "platform_analytics_revenue_idx")
}

// Chat and AI models (unchanged but with performance indexes)
model ChatConversation {
  id         String       @id @default(cuid())
  title      String?
  userId     String
  videoId    String?
  context    Json         // Stores ChatContext as JSON
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  video    Video?        @relation(fields: [videoId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([userId], name: "chat_user_id_idx")
  @@index([videoId], name: "chat_video_id_idx")
  @@index([isActive], name: "chat_active_idx")
  @@index([createdAt], name: "chat_created_at_idx")
  @@index([userId, isActive], name: "chat_user_active_idx")
}

model ChatMessage {
  id             String   @id @default(cuid())
  content        String   @db.Text
  role           String   // 'user' | 'assistant'
  conversationId String
  metadata       Json?    // Stores metadata like commands, actions, context
  createdAt      DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId], name: "message_conversation_id_idx")
  @@index([createdAt], name: "message_created_at_idx")
  @@index([role], name: "message_role_idx")
  @@index([conversationId, createdAt], name: "message_conversation_time_idx")
}

// Additional utility models
model HashtagTrend {
  id              String            @id @default(cuid())
  hashtag         String
  platform        String
  trending        Boolean           @default(false)
  volume          BigInt            @default(0)
  growthRate      Float             @default(0.0)
  category        String?
  sentiment       Float             @default(0.0)
  lastUpdated     DateTime          @default(now())
  createdAt       DateTime          @default(now())

  @@unique([hashtag, platform])
  @@index([hashtag], name: "hashtag_hashtag_idx")
  @@index([platform], name: "hashtag_platform_idx")
  @@index([trending], name: "hashtag_trending_idx")
  @@index([volume], name: "hashtag_volume_idx")
  @@index([lastUpdated], name: "hashtag_updated_idx")
  @@index([platform, trending], name: "hashtag_platform_trending_idx")
}

model OptimalPostingTime {
  id              String            @id @default(cuid())
  accountId       String
  dayOfWeek       Int               // 0-6 (Sunday to Saturday)
  hour            Int               // 0-23
  timezone        String
  engagementScore Float             @default(0.0)
  lastCalculated  DateTime          @default(now())
  createdAt       DateTime          @default(now())

  account         PlatformAccount   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, dayOfWeek, hour])
  @@index([accountId], name: "posting_time_account_idx")
  @@index([dayOfWeek], name: "posting_time_day_idx")
  @@index([hour], name: "posting_time_hour_idx")
  @@index([engagementScore], name: "posting_time_score_idx")
  @@index([accountId, engagementScore], name: "posting_time_account_score_idx")
}

model ScheduledPost {
  id              String            @id @default(cuid())
  campaignId      String
  accountId       String
  scheduledAt     DateTime
  status          SchedulingStatus  @default(PENDING)
  priority        Int               @default(5)    // 1-10, higher is more important
  attemptCount    Int               @default(0)
  maxAttempts     Int               @default(3)
  lastAttempt     DateTime?
  nextAttempt     DateTime?
  errorMessage    String?           @db.Text
  processingData  Json              @default("{}")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  campaign        PublishingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  account         PlatformAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([scheduledAt], name: "scheduled_post_scheduled_idx")
  @@index([status], name: "scheduled_post_status_idx")
  @@index([accountId], name: "scheduled_post_account_idx")
  @@index([priority], name: "scheduled_post_priority_idx")
  @@index([nextAttempt], name: "scheduled_post_next_attempt_idx")
  @@index([status, scheduledAt], name: "scheduled_post_status_time_idx")
}

model ContentOptimization {
  id              String            @id @default(cuid())
  campaignId      String
  platformName    String
  originalVideoUrl String
  optimizedVideoUrl String?
  originalThumbnailUrl String?
  optimizedThumbnailUrl String?
  targetAspectRatio String          // '9:16', '16:9', '1:1'
  targetDuration  Int?              // in seconds
  targetFileSize  BigInt?           // in bytes
  targetQuality   String            // 'low', 'medium', 'high'
  compressionSettings Json         @default("{}")
  status          OptimizationStatus @default(PENDING)
  progress        Int               @default(0)    // 0-100
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?           @db.Text
  metadata        Json              @default("{}")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  campaign        PublishingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId], name: "optimization_campaign_idx")
  @@index([platformName], name: "optimization_platform_idx")
  @@index([status], name: "optimization_status_idx")
  @@index([progress], name: "optimization_progress_idx")
  @@index([createdAt], name: "optimization_created_at_idx")
  @@index([status, createdAt], name: "optimization_status_time_idx")
}

model PublishingHistory {
  id              String            @id @default(cuid())
  campaignId      String
  accountId       String
  action          String            // 'CREATED', 'SCHEDULED', 'PUBLISHED', 'FAILED', 'CANCELLED', 'RETRIED'
  status          String
  message         String?           @db.Text
  errorDetails    Json?
  metadata        Json              @default("{}")
  timestamp       DateTime          @default(now())
  userId          String?
  ipAddress       String?
  userAgent       String?           @db.Text

  campaign        PublishingCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  account         PlatformAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user            User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([campaignId], name: "history_campaign_idx")
  @@index([accountId], name: "history_account_idx")
  @@index([action], name: "history_action_idx")
  @@index([timestamp], name: "history_timestamp_idx")
  @@index([userId], name: "history_user_idx")
  @@index([accountId, timestamp], name: "history_account_time_idx")
}

// New subscription and billing models
model UserSubscription {
  id              String            @id @default(cuid())
  userId          String
  tier            UserTier
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime          @default(now())
  endDate         DateTime?
  autoRenew       Boolean           @default(true)
  
  // Billing
  amount          Float
  currency        String            @default("USD")
  billingCycle    BillingCycle      @default(MONTHLY)
  nextBillingDate DateTime?
  
  // Usage tracking
  videosProcessed Int               @default(0)
  storageUsed     BigInt            @default(0)
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "subscription_user_idx")
  @@index([status], name: "subscription_status_idx")
  @@index([endDate], name: "subscription_end_date_idx")
  @@index([nextBillingDate], name: "subscription_billing_idx")
}

